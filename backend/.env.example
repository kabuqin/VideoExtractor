APP_NAME="Short Video Copywriter"
API_PREFIX="/api"
DATABASE_URL="sqlite:///./data/app.db"
STORAGE_ROOT="../storage"
DOWNLOAD_TIMEOUT_SECONDS=600
WHISPER_MODEL="small"
WHISPER_DEVICE="auto"
WHISPER_COMPUTE_TYPE="auto"

# LLM API Configuration
# OpenAI: LLM_BASE_URL="https://api.openai.com/v1", LLM_MODEL="gpt-4o-mini"
# 通义千问: LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1", LLM_MODEL="qwen-plus"
# Ollama本地: LLM_BASE_URL="http://localhost:11434/v1", LLM_MODEL="qwen2.5:7b"
LLM_API_KEY=""
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL="gpt-4o-mini"
LLM_TIMEOUT_SECONDS=120

# YouTube Cookie (optional)
# Required for downloading YouTube videos (bot protection)
# 1. Install browser extension: "Get cookies.txt LOCALLY"
# 2. Login to YouTube, export cookies to netscape format
# 3. Save file and set path below
YOUTUBE_COOKIES_FILE=""
